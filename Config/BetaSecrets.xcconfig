// BetaSecrets.xcconfig
//
// Default (empty) values for credentials baked into the .app at build time.
// To populate them for a beta build, copy this file to
// `Config/BetaSecrets.local.xcconfig` and fill in your values there — the
// .local.xcconfig variant is gitignored. Anything you set there overrides the
// empty defaults below via the optional include at the bottom of this file.
//
// Variable                         Purpose
// ----------------                 -----------------------------------------
// PIDGY_TG_API_ID                  Your app's Telegram api_id (from
//                                  https://my.telegram.org/apps). Numeric.
// PIDGY_TG_API_HASH                Your app's Telegram api_hash from the
//                                  same page. Hex string.
// PIDGY_BUNDLED_OPENAI_API_KEY     OpenAI API key to bake into the build for
//                                  zero-config beta testers. Leave empty to
//                                  force BYO-key in the AI Settings page.
//
// SECURITY: any value baked into a non-key-stripped .app is extractable via
// `strings`. For OpenAI, only embed a key with a low monthly hard cap (set
// at platform.openai.com/account/limits) and rotate before the cohort grows.

PIDGY_TG_API_ID =
PIDGY_TG_API_HASH =
PIDGY_BUNDLED_OPENAI_API_KEY =

// Filled in by the postBuildScripts step from `git rev-parse --short HEAD`.
// Default placeholder lets Info.plist substitution succeed for trees that
// aren't a git checkout (e.g., release tarballs).
PIDGY_BUILD_COMMIT_SHA = unknown

#include? "BetaSecrets.local.xcconfig"
