// BetaSecrets.xcconfig
//
// Default (empty) values for credentials baked into the .app at build time.
// To populate them for a beta build, copy this file to
// `Config/BetaSecrets.local.xcconfig` and fill in your values there — the
// .local.xcconfig variant is gitignored. Anything you set there overrides the
// empty defaults below via the optional include at the bottom of this file.
//
// Variable                         Purpose
// ----------------                 -----------------------------------------
// PIDGY_TG_API_ID                  Your app's Telegram api_id (from
//                                  https://my.telegram.org/apps). Numeric.
// PIDGY_TG_API_HASH                Your app's Telegram api_hash from the
//                                  same page. Hex string.
// PIDGY_BUNDLED_OPENAI_API_KEY     OpenAI API key to bake into the build for
//                                  zero-config beta testers. Leave empty to
//                                  force BYO-key in the AI Settings page.
//                                  CUTOVER (issue #26): once the AI proxy is
//                                  deployed and verified, bind this only under
//                                  [config=Debug] and blank [config=Release]
//                                  in your .local.xcconfig so the raw key
//                                  never ships again.
//                                  See infra/ai-proxy/README.md.
// PIDGY_AI_PROXY_URL               Full chat-completions URL of the deployed
//                                  AI proxy Worker (infra/ai-proxy). When set
//                                  together with PIDGY_AI_PROXY_TOKEN, the
//                                  zero-setup flow sends AI requests through
//                                  the proxy with the gate token instead of
//                                  bundling the OpenAI key. Escape '/' as
//                                  /$()/ (same rule as the Sentry DSN).
// PIDGY_AI_PROXY_TOKEN             Gate token the app presents to the proxy
//                                  (matches the Worker secret
//                                  PIDGY_PROXY_TOKEN). Bundled → extractable,
//                                  but revocable and worthless outside the
//                                  proxy. Leave both empty for the current
//                                  direct-key behavior.
// PIDGY_DODO_BASE_URL              Dodo Payments API host for the public
//                                  license endpoints (activate/validate/
//                                  deactivate). Test: https:/$()/test.dodopayments.com
//                                  Live: https:/$()/live.dodopayments.com .
//                                  Escape '/' as /$()/ — xcconfig treats // as
//                                  a comment. Blank → defaults to test.
// PIDGY_DODO_CHECKOUT_BYOK         Hosted checkout link for the BYOK product
//                                  (Dodo product page → payment link). Same '/'
//                                  escaping. The product id in the URL also
//                                  drives the activate-response → tier mapping.
// PIDGY_DODO_CHECKOUT_BUNDLED      Hosted checkout link for the Managed product.
// PIDGY_SENTRY_DSN                 Sentry DSN for crash + error telemetry.
//                                  Leave empty to skip Sentry init entirely
//                                  (no network requests, no SDK warmup).
//                                  Note: '/' in URLs interferes with xcconfig
//                                  variable resolution; escape forward slashes
//                                  here with `$()` separators if needed:
//                                  `https:/$()/abc@o123.ingest...`.
// PIDGY_SENTRY_AUTH_TOKEN          Auth token for sentry-cli dSYM upload.
//                                  Required for symbolicated crash traces.
//                                  Create at sentry.io/orgsettings/auth-tokens
//                                  with `project:releases` + `project:write`
//                                  scope. Leave empty to skip dSYM upload —
//                                  events still flow but stack frames will
//                                  show memory addresses, not source lines.
// PIDGY_SENTRY_ORG                 Sentry organization slug (from the URL
//                                  bar, e.g. `acme-corp`).
// PIDGY_SENTRY_PROJECT             Sentry project slug (e.g. `pidgy`).
//
// SECURITY: any value baked into a non-key-stripped .app is extractable via
// `strings`. For OpenAI, only embed a key with a low monthly hard cap (set
// at platform.openai.com/account/limits) and rotate before the cohort grows.

PIDGY_TG_API_ID =
PIDGY_TG_API_HASH =
PIDGY_BUNDLED_OPENAI_API_KEY =
PIDGY_AI_PROXY_URL =
PIDGY_AI_PROXY_TOKEN =
PIDGY_DODO_BASE_URL =
PIDGY_DODO_CHECKOUT_BYOK =
PIDGY_DODO_CHECKOUT_BUNDLED =
PIDGY_DODO_PORTAL_URL =
PIDGY_SENTRY_DSN =
PIDGY_SENTRY_AUTH_TOKEN =
PIDGY_SENTRY_ORG =
PIDGY_SENTRY_PROJECT =

// Filled in by the postBuildScripts step from `git rev-parse --short HEAD`.
// Default placeholder lets Info.plist substitution succeed for trees that
// aren't a git checkout (e.g., release tarballs).
PIDGY_BUILD_COMMIT_SHA = unknown

#include? "BetaSecrets.local.xcconfig"
