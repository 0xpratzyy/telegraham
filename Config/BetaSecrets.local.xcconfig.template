// BetaSecrets.local.xcconfig
//
// Copy this file to `BetaSecrets.local.xcconfig` (drop the `.template`
// suffix) and replace each value with your real credential. The .local.
// xcconfig variant is gitignored so secrets never land in version control.
//
// After editing, rerun `xcodegen generate` and rebuild. Bundle.main reads
// the values back through the keys defined in Info.plist — see
// `Sources/App/BundledSecrets.swift`.

PIDGY_TG_API_ID = 1234567
PIDGY_TG_API_HASH = abcdef0123456789abcdef0123456789
PIDGY_BUNDLED_OPENAI_API_KEY = sk-paste-your-beta-key-here

// AI proxy (issue #26) — deploy infra/ai-proxy first (see its README), then
// fill both values and the zero-setup flow stops needing the bundled OpenAI
// key. The `//` in the URL must be escaped as `/$()/`. Example:
// PIDGY_AI_PROXY_URL = https:/$()/pidgy-ai-proxy.<account>.workers.dev/v1/chat/completions
PIDGY_AI_PROXY_URL =
PIDGY_AI_PROXY_TOKEN =
// CUTOVER once a proxied build is verified: stop shipping the raw key in
// Release by replacing the PIDGY_BUNDLED_OPENAI_API_KEY line above with a
// Debug/Release config split (keep Debug for dev loops), then rotate the
// old key:
// PIDGY_BUNDLED_OPENAI_API_KEY[config=Debug] = sk-paste-your-beta-key-here
// PIDGY_BUNDLED_OPENAI_API_KEY[config=Release] =
// Sentry DSN — leave blank to disable telemetry. The `//` in the URL must be
// escaped as `/$()/` so xcconfig doesn't read it as a comment. Example:
// PIDGY_SENTRY_DSN = https:/$()/abc123@o456.ingest.us.sentry.io/789
PIDGY_SENTRY_DSN =

// Auth token + org/project for dSYM upload. Without these, crash traces in
// Sentry show memory addresses instead of source lines. Create the token at
// sentry.io/orgsettings/auth-tokens with `project:releases` + `project:write`.
PIDGY_SENTRY_AUTH_TOKEN =
PIDGY_SENTRY_ORG =
PIDGY_SENTRY_PROJECT =

// NOTE: the LangSmith tracing variables were removed deliberately. LLM
// traces (raw prompts + responses, including Telegram message text) are
// written by LocalAITraceRecorder to a local JSONL file only —
// ~/Library/Application Support/Pidgy/traces/ — in Debug builds. No
// remote tracing endpoint or key exists in the app anymore.
