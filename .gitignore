# Xcode
*.xcworkspace/
DerivedData/
*.xcuserdata/
*.xcscmblueprint
*.xccheckout

# Build
build/
.build/

# LLVM code-coverage artifacts (emitted at repo root on instrumented runs).
*.profraw

# Pidgy.xcodeproj is generated by xcodegen (project.yml is the source of
# truth), so nothing inside is tracked EXCEPT the SPM Package.resolved,
# which pins dependency versions so CI / a second machine / release day
# all build the same GRDB/Sentry/Sparkle. Git can't re-include a file
# whose parent directory is excluded, hence the ignore-children +
# negate-one-path chain below instead of a plain `*.xcodeproj/`.
# (The negation lines must stay AFTER the `*.xcworkspace/` rule above —
# last match wins.)
Pidgy.xcodeproj/*
!Pidgy.xcodeproj/project.xcworkspace
Pidgy.xcodeproj/project.xcworkspace/*
!Pidgy.xcodeproj/project.xcworkspace/xcshareddata
Pidgy.xcodeproj/project.xcworkspace/xcshareddata/*
!Pidgy.xcodeproj/project.xcworkspace/xcshareddata/swiftpm
Pidgy.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!Pidgy.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# SPM
.swiftpm/
# Cloned package checkouts (xcodebuild -clonedSourcePackagesDirPath,
# used by CI and local test runs so SPM caching is path-stable).
SourcePackages/

# macOS
.DS_Store
*.swp
*~

# IDE
.idea/
.vscode/

# Agent skill installs (per-contributor; install via `npx skills add ...`).
.agents/
.claude/skills/
skills-lock.json

# Beta credentials baked into the build via xcconfig — never check these in.
Config/BetaSecrets.local.xcconfig

# Eval harness secrets + outputs (tools/model_swap_eval.py). The .local file
# holds OPENROUTER_API_KEY / LANGSMITH_API_KEY; never check it in.
.env.eval.local
.env.eval
tools/model_swap_eval_out/
__pycache__/

# Packaged distribution artifacts (Pidgy-<sha>.dmg etc.)
dist/

# Coding-agent / LLM session transcripts. Belt-and-suspenders for a real
# incident: one such file (yc-coding-agent-session-pidgy-evals.md) landed
# in the repo root with raw Telegram api_id / api_hash bytes in it. It
# wasn't tracked, but a single `git add .` would have committed it. These
# patterns make sure no future transcript drop ever ends up staged.
yc-coding-agent-session-*.md
*-coding-agent-session-*.md
*-session-transcript-*.md
*-eval-session-*.md
.claude/worktrees/*/yc-coding-agent-session-*.md

# wrangler local state (account cache, dev logs)
.wrangler/
SourcePccages/
